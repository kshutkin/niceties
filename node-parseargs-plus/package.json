{
    "version": "0.1.0",
    "license": "MIT",
    "name": "@niceties/node-parseargs-plus",
    "author": {
        "name": "Konstantin Shutkin"
    },
    "type": "module",
    "types": "./types/index.d.ts",
    "exports": {
        ".": {
            "types": "./types/index.d.ts",
            "default": "./src/index.js"
        },
        "./help": {
            "types": "./types/index.d.ts",
            "default": "./src/help.js"
        },
        "./commands": {
            "types": "./types/index.d.ts",
            "default": "./src/commands.js"
        },
        "./parameters": {
            "types": "./types/index.d.ts",
            "default": "./src/parameters.js"
        },
        "./package.json": "./package.json"
    },
    "main": "./src/index.js",
    "module": "./src/index.js",
    "files": [
        "src/*.js",
        "types"
    ],
    "engines": {
        "node": ">=18.3.0"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/kshutkin/niceties.git"
    },
    "bugs": {
        "url": "https://github.com/kshutkin/niceties/issues"
    },
    "homepage": "https://github.com/kshutkin/niceties/blob/main/node-parseargs-plus/README.md",
    "readme": "README.md",
    "description": "Enhanced wrapper around Node.js util.parseArgs",
    "keywords": [
        "@niceties",
        "parseargs",
        "cli",
        "arguments",
        "options"
    ],
    "scripts": {
        "build": "dts-buddy -m @niceties/node-parseargs-plus:src/exports.d.ts -m @niceties/node-parseargs-plus/help:src/help-exports.d.ts -m @niceties/node-parseargs-plus/commands:src/commands-exports.d.ts -m @niceties/node-parseargs-plus/parameters:src/parameters-exports.d.ts",
        "prepack": "pkgprn-internal --flatten types,src --strip-comments --remove-sourcemaps",
        "test": "vitest run --coverage --config ../vitest.config.js"
    },
    "dependencies": {
        "@niceties/ansi": "workspace:^"
    }
}
